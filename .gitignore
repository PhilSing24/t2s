# Build outputs
build/
cpp/build/

# C++ build artifacts (escaped from build dirs)
*.o
*.a
*.so
*.dylib

# Logs (keep folder structure, ignore contents)
logs/*.log
logs/processes/*.log
kdb/logs/

# Runtime scratch
run/
tmp/
tmp.*/

# HDB (runtime data, not source)
hdb/
hdb_binancedata/

# kdb+ artifacts
*.qdb

# Core dumps
core
core.*

# Python / Jupyter
.venv/
__pycache__/
.ipynb_checkpoints/

# Local config overrides
config/*.local.json

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
kdb/tick/logs/
*:Zone.Identifier
kdb/tick/baseline
kdb/tick/baseline_pr2
